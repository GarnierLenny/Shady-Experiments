{
  "name": "shadyexperiments",
  "version": "0.1.0",
  "private": true,
  "description": "ShadyExperiments — a collection of social experiments. One central API, experiments served as Multi-Zones.",
  "workspaces": [
    "packages/*",
    "apps/api",
    "apps/web/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:shared": "npm run build -w @shadyexperiments/shared",
    "build:db": "npm run build -w @shadyexperiments/db",
    "predev": "npm run build:shared && npm run build:db",
    "dev": "concurrently -n shared,api,web -c gray,cyan,blue \"npm:dev:shared\" \"npm:dev:api\" \"npm:dev:landing\"",
    "dev:shared": "npm run dev -w @shadyexperiments/shared",
    "dev:api": "npm run dev -w @shadyexperiments/api",
    "dev:landing": "npm run dev -w landing"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
